APP_NAME=Stock RAG Research Assistant
APP_ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://your_user:your_password@127.0.0.1:5432/stock_rag

# Retrieval
DEFAULT_TOP_K=5
MIN_ANSWER_SCORE=0.015

# Embedding
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT_SECONDS=60

# LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.1
